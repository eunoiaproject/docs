{
    "name": "eunoiaproject/eunoiaverse",
    "description": "A comprehensive PHP platform for digital content creation, e-commerce marketplace, and wallet management",
    "type": "library",
    "version": "1.2.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Edo Erpani",
            "email": "edo@eunoiaverse.local",
            "role": "CEO"
        },
        {
            "name": "EdoErpani",
            "role": "Senior Software Engineer"
        }
    ],
    "homepage": "https://github.com/eunoiaproject/eunoiaverse",
    "repository": {
        "type": "git",
        "url": "https://github.com/eunoiaproject/eunoiaverse.git"
    },
    "require": {
        "php": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Eunoiaverse\\": "src/",
            "Eunoiaverse\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "dev": "php -S localhost:8080",
        "build": "composer install",
        "db:create": "php bin/setup-db.php",
        "validate": "php bin/validate.php"
    },
    "extra": {
        "project": {
            "status": "Active",
            "team": "Frontend",
            "deploymentEnvironments": [
                {
                    "name": "Development",
                    "url": "https://github.com/eunoiaproject/developmet",
                    "branch": "development"
                },
                {
                    "name": "Staging",
                    "url": "https://eunoiaverse.com",
                    "branch": "release/v1.2"
                },
                {
                    "name": "Production",
                    "url": "https://github.com/eunoiaproject/android",
                    "branch": "main"
                }
            ]
        }
    }
}